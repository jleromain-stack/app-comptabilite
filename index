function importData(e) {
  var file = e.target.files[0];
  if (!file) return;
  var r = new FileReader();
  r.onload = function(ev) {
    try {
      var b = JSON.parse(ev.target.result);
      if (!b.accounts) { showToast('Fichier invalide'); return; }
      if (!confirm('Importer ? Les données actuelles seront remplacées.')) return;
      saveAccounts(b.accounts);
      var k;
      for (k in (b.data||{})) localStorage.setItem(k, JSON.stringify(b.data[k]));
      for (k in (b.notes||{})) localStorage.setItem(k, JSON.stringify(b.notes[k]));
      renderHome();
      showToast('Données restaurées ✓');
    } catch(err) { showToast('Erreur import'); }
  };
  r.readAsText(file);
  e.target.value = '';
}

