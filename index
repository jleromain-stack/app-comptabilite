<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MonBudget</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#EDFAF3;--bg-alt:#F5FDF8;--white:#FFF;
  --forest:#182E22;--forest-mid:#2A4A36;
  --green:#4DB876;--green-light:#C8F0D8;--green-dark:#2A7A4A;
  --raspberry:#C8526E;--raspberry-light:#F5D5DC;--raspberry-dark:#A03050;
  --amber:#D4860A;--amber-bg:#FDF3DC;--amber-border:#F0C060;
  --muted:#6A8C76;--border:#B8D8C4;--r:14px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--forest);font-family:'Outfit',sans-serif;font-weight:300;font-size:15px;line-height:1.6;}
.screen{position:fixed;inset:0;display:none;flex-direction:column;overflow:hidden;}
.screen.active{display:flex;}
#screen-pin{background:var(--forest);align-items:center;justify-content:center;}
.pin-logo{font-size:28px;font-weight:800;color:var(--bg);letter-spacing:-0.03em;margin-bottom:6px;}
.pin-logo span{color:var(--green);}
.pin-sub{font-size:12px;color:var(--muted);margin-bottom:36px;text-align:center;padding:0 20px;}
.pin-dots{display:flex;gap:16px;margin-bottom:28px;}
.pin-dot{width:16px;height:16px;border-radius:50%;border:2px solid rgba(255,255,255,.3);background:transparent;transition:.2s;}
.pin-dot.filled{background:var(--green);border-color:var(--green);}
.pin-error{color:var(--raspberry);font-size:13px;margin-bottom:14px;min-height:20px;text-align:center;}
.pin-pad{display:grid;grid-template-columns:repeat(3,72px);gap:12px;}
.pin-btn{width:72px;height:72px;border-radius:50%;border:1.5px solid rgba(255,255,255,.15);background:rgba(255,255,255,.07);color:#fff;font-size:22px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.pin-btn:active{transform:scale(.93);}
.pin-btn.del{font-size:18px;background:transparent;border-color:transparent;}
.pin-btn.zero{grid-column:2;}
.pin-setup{margin-top:26px;font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline dotted;}
#screen-home{background:var(--bg);}
.home-nav{background:var(--forest);padding:14px 18px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.home-logo{font-weight:800;font-size:17px;color:var(--bg);}
.home-logo span{color:var(--green);}
.home-nav-btns{display:flex;gap:7px;}
.btn-icon{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:#fff;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;font-family:'Outfit',sans-serif;}
.home-body{flex:1;overflow-y:auto;padding:18px 14px 30px;}
.home-title{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.accounts-grid{display:flex;flex-direction:column;gap:10px;}
.account-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:16px;cursor:pointer;}
.ac-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.ac-name{font-size:16px;font-weight:700;color:var(--forest);}
.ac-sync{font-size:10px;color:var(--muted);margin-top:2px;}
.ac-actions{display:flex;gap:6px;}
.ac-btn{background:none;border:none;cursor:pointer;font-size:16px;line-height:1;padding:2px;color:var(--muted);}
.ac-soldes{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;}
.ac-solde{text-align:center;}
.ac-solde-label{font-size:9px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.ac-solde-val{font-size:15px;font-weight:800;line-height:1.2;}
.ac-solde-val.actuel{color:var(--forest);}
.ac-solde-val.avenir{color:var(--amber);}
.ac-solde-val.projete{color:var(--green-dark);}
.ac-solde-val.danger{color:var(--raspberry);}
.btn-new-account{background:var(--forest);color:var(--bg);border:none;border-radius:100px;padding:12px 22px;font-size:14px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;width:100%;margin-top:14px;}
#screen-account{background:var(--bg);}
.acc-nav{background:var(--forest);padding:11px 14px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;gap:7px;}
.btn-back{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:#fff;padding:6px 12px;border-radius:100px;font-size:12px;font-weight:500;cursor:pointer;font-family:'Outfit',sans-serif;}
.acc-nav-title{font-weight:700;font-size:14px;color:#fff;flex:1;text-align:center;cursor:pointer;}
.acc-nav-right{display:flex;gap:5px;}
.nav-month-pill{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:#fff;padding:0 9px;border-radius:100px;font-size:11px;font-weight:700;height:28px;display:flex;align-items:center;}
.acc-tabs{display:flex;background:var(--forest-mid);flex-shrink:0;}
.acc-tab{flex:1;padding:9px 4px;font-size:11px;font-weight:600;color:rgba(255,255,255,.5);text-align:center;cursor:pointer;border-bottom:2px solid transparent;}
.acc-tab.active{color:#fff;border-bottom-color:var(--green);}
.soldes{display:grid;grid-template-columns:1fr 1fr 1fr;background:var(--white);border-bottom:2px solid var(--border);flex-shrink:0;}
.solde-card{padding:11px 7px;text-align:center;}
.solde-card+.solde-card{border-left:1px solid var(--border);}
.solde-label{font-size:9px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;margin-bottom:3px;}
.solde-label.l-a{color:var(--forest);}
.solde-label.l-d{color:var(--amber);}
.solde-label.l-p{color:var(--green-dark);}
.solde-num{font-size:16px;font-weight:800;letter-spacing:-0.02em;line-height:1.1;}
.solde-num.actuel{color:var(--forest);}
.solde-num.avenir{color:var(--amber);}
.solde-num.projete{color:var(--green-dark);}
.solde-num.danger{color:var(--raspberry);}
.solde-sub{font-size:8px;color:var(--muted);margin-top:2px;}
.solde-edit-btn{background:none;border:none;cursor:pointer;font-size:9px;color:var(--muted);margin-top:1px;font-family:'Outfit',sans-serif;text-decoration:underline dotted;}
.solde-input-inline{font-size:15px;font-weight:800;width:90%;border:none;border-bottom:2px solid var(--green);outline:none;background:transparent;color:var(--forest);font-family:'Outfit',sans-serif;text-align:center;}
.sync-bar{background:var(--forest-mid);padding:7px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:7px;}
.sync-info{font-size:10px;color:rgba(255,255,255,.6);flex:1;}
.sync-info strong{color:#fff;}
.sync-ecart{font-size:10px;font-weight:600;padding:3px 8px;border-radius:100px;flex-shrink:0;}
.sync-ecart.ok{background:var(--green-light);color:var(--green-dark);}
.sync-ecart.warn{background:var(--raspberry-light);color:var(--raspberry);}
.btn-sync{background:var(--green);color:var(--forest);border:none;border-radius:100px;padding:5px 11px;font-size:11px;font-weight:700;font-family:'Outfit',sans-serif;cursor:pointer;}
.legend{display:flex;background:rgba(24,46,34,.85);flex-shrink:0;}
.legend-item{flex:1;display:flex;align-items:center;justify-content:center;gap:4px;padding:5px 3px;font-size:9px;font-weight:500;color:rgba(255,255,255,.6);}
.legend-dot{width:6px;height:6px;border-radius:50%;}
.ld-eff{background:var(--raspberry);}
.ld-prog{background:var(--amber);}
.ld-rec{background:var(--green);}
.tab-panel{display:none;flex:1;overflow-y:auto;}
.tab-panel.active{display:block;}
#dep-body{padding:10px 12px 80px;}
.sec-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;margin-top:16px;}
.sec-header:first-child{margin-top:0;}
.sec-title-wrap{display:flex;align-items:center;gap:6px;}
.sec-title{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.sec-count{background:var(--border);color:var(--forest-mid);font-size:9px;font-weight:600;padding:1px 6px;border-radius:100px;}
.btn-add{border:none;border-radius:100px;padding:6px 13px;font-size:12px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;}
.btn-add.forest{background:var(--forest);color:var(--bg);}
.btn-add.green{background:var(--green);color:var(--forest);}
.btn-add.amber{background:var(--amber);color:#fff;}
.btn-add.cam{background:var(--raspberry);color:#fff;}
.items{display:flex;flex-direction:column;gap:6px;}
.empty{text-align:center;color:var(--muted);font-size:13px;padding:14px;border:1.5px dashed var(--border);border-radius:var(--r);}
.item{background:var(--white);border:1.5px solid var(--border);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:8px;cursor:pointer;}
.item.effectuee{border-left:3px solid var(--raspberry);background:#FDF8F9;}
.item.programmee{border-left:3px solid var(--amber);background:var(--amber-bg);border-color:var(--amber-border);}
.item.reconciliee{border-left:3px solid var(--green);background:#F2FCF6;}
.item.revenu{border-left:3px solid var(--green);background:#F0FAF4;}
.item-body{flex:1;min-width:0;}
.item-row1{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.item-label{font-size:13px;font-weight:600;color:var(--forest);}
.item.effectuee .item-label{text-decoration:line-through;text-decoration-color:rgba(200,82,110,.4);}
.cat-pill{display:inline-flex;padding:1px 7px;border-radius:100px;font-size:9px;font-weight:700;white-space:nowrap;}
.item-row2{display:flex;align-items:center;gap:6px;margin-top:2px;}
.item-date{font-size:10px;color:var(--muted);}
.item-state{font-size:9px;font-weight:700;padding:1px 6px;border-radius:100px;}
.item-state.eff{background:var(--raspberry-light);color:var(--raspberry-dark);}
.item-state.prog{background:var(--amber-bg);color:var(--amber);}
.item-state.rec{background:var(--green-light);color:var(--green-dark);}
.item-state.rev{background:var(--green-light);color:var(--green-dark);}
.item-check{width:20px;height:20px;border-radius:6px;border:2px solid var(--border);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--white);}
.item.programmee .item-check{border-color:var(--amber-border);background:var(--amber-bg);}
.item.reconciliee .item-check{background:var(--green);border-color:var(--green);}
.item-check svg{width:10px;height:10px;stroke:white;stroke-width:3;fill:none;display:none;}
.item.reconciliee .item-check svg{display:block;}
.item-amount{font-size:14px;font-weight:800;flex-shrink:0;}
.dup-bar{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:11px 14px;display:flex;align-items:center;justify-content:space-between;margin-top:16px;border-left:3px solid var(--green);}
.dup-text{font-size:11px;color:var(--muted);}
.dup-text strong{color:var(--forest);font-weight:600;}
.btn-dup{background:var(--green);color:var(--forest);border:none;border-radius:100px;padding:6px 13px;font-size:11px;font-weight:700;font-family:'Outfit',sans-serif;cursor:pointer;}
#panel-stats{padding:12px 12px 30px;overflow-y:auto;}
.stats-period{display:flex;gap:6px;margin-bottom:14px;}
.period-btn{background:var(--white);border:1.5px solid var(--border);border-radius:100px;padding:5px 13px;font-size:11px;font-weight:600;color:var(--muted);cursor:pointer;font-family:'Outfit',sans-serif;}
.period-btn.active{background:var(--forest);color:var(--bg);border-color:var(--forest);}
.stats-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:12px;}
.stats-h{font-size:12px;font-weight:700;color:var(--forest);margin-bottom:12px;}
.chart-bars{display:flex;flex-direction:column;gap:8px;}
.bar-row{display:flex;align-items:center;gap:8px;}
.bar-cat{font-size:10px;font-weight:600;width:82px;flex-shrink:0;text-align:right;}
.bar-track{flex:1;background:var(--bg);border-radius:100px;height:14px;overflow:hidden;}
.bar-fill{height:100%;border-radius:100px;transition:.4s;}
.bar-amt{font-size:10px;font-weight:700;width:62px;flex-shrink:0;}
.pie-wrap{display:flex;justify-content:center;margin-bottom:12px;}
.pie-legend{display:flex;flex-direction:column;gap:5px;}
.pie-leg-row{display:flex;align-items:center;gap:7px;font-size:11px;}
.pie-leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.pie-leg-name{flex:1;color:var(--forest);font-weight:500;}
.pie-leg-pct{font-weight:700;color:var(--muted);}
.livre-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding:12px 12px 0;}
.livre-title{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.note-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:10px;cursor:pointer;}
.note-date{font-size:10px;color:var(--muted);margin-bottom:4px;}
.note-preview{font-size:13px;color:var(--forest);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;}
.mic-fab{position:fixed;bottom:20px;right:16px;width:48px;height:48px;border-radius:50%;background:var(--raspberry);border:2px solid var(--forest);box-shadow:3px 3px 0 var(--forest);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:50;}
.mic-fab.listening{background:var(--green);animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{box-shadow:3px 3px 0 var(--forest);}50%{box-shadow:0 0 0 8px rgba(77,184,118,.2),3px 3px 0 var(--forest);}}
.overlay{display:none;position:fixed;inset:0;background:rgba(24,46,34,.6);z-index:200;align-items:flex-end;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:var(--white);border-radius:20px 20px 0 0;padding:22px 18px 36px;width:100%;max-width:480px;max-height:88vh;overflow-y:auto;}
.modal-title{font-size:16px;font-weight:700;margin-bottom:16px;color:var(--forest);}
.field{margin-bottom:13px;}
.field label{display:block;font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.field input[type=text],.field input[type=number],.field input[type=password],.field select,.field textarea{width:100%;border:1.5px solid var(--border);border-radius:10px;padding:10px 12px;font-size:15px;font-family:'Outfit',sans-serif;color:var(--forest);background:var(--bg);outline:none;-webkit-appearance:none;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--green);}
.field textarea{resize:vertical;min-height:100px;line-height:1.6;}
.modal-btns{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;}
.btn-save{flex:1;min-width:80px;background:var(--forest);color:var(--bg);border:none;border-radius:100px;padding:12px;font-size:14px;font-weight:600;font-family:'Outfit',sans-serif;cursor:pointer;}
.btn-cancel{background:transparent;color:var(--muted);border:1.5px solid var(--border);border-radius:100px;padding:12px 16px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;}
.btn-delete-item{background:var(--raspberry-light);color:var(--raspberry-dark);border:1.5px solid #E8B8C4;border-radius:100px;padding:12px 14px;font-size:14px;font-family:'Outfit',sans-serif;cursor:pointer;font-weight:600;}
.info-box{background:var(--amber-bg);border:1.5px solid var(--amber-border);border-radius:10px;padding:10px;margin-bottom:12px;font-size:12px;color:#7A4800;}
.info-box strong{display:block;font-size:13px;font-weight:700;margin-bottom:2px;}
.cal-wrap{background:var(--bg);border:1.5px solid var(--border);border-radius:10px;overflow:hidden;margin-top:4px;}
.cal-nav{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--forest);}
.cal-nav-btn{background:none;border:none;color:#fff;font-size:18px;cursor:pointer;padding:0 6px;font-family:'Outfit',sans-serif;}
.cal-nav-label{font-size:13px;font-weight:700;color:#fff;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;padding:6px;}
.cal-head{text-align:center;font-size:9px;font-weight:700;color:var(--muted);padding:3px 0;}
.cal-day{text-align:center;font-size:12px;padding:6px 2px;border-radius:6px;cursor:pointer;color:var(--forest);}
.cal-day:hover{background:var(--green-light);}
.cal-day.selected{background:var(--green);color:#fff;font-weight:700;}
.cal-day.today-mark{font-weight:700;color:var(--raspberry);}
.cal-day.empty{cursor:default;}
.cal-selected-display{padding:8px 12px;font-size:13px;font-weight:600;color:var(--forest);border-top:1px solid var(--border);text-align:center;}
.palette-grid{display:flex;flex-wrap:wrap;gap:10px;padding:8px 0;}
.palette-dot{width:36px;height:36px;border-radius:50%;cursor:pointer;transition:.15s;border:3px solid transparent;}
.palette-dot.selected{border-color:var(--forest);box-shadow:0 0 0 2px var(--green);}
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--forest);color:var(--bg);padding:9px 18px;border-radius:100px;font-size:12px;font-weight:500;opacity:0;transition:.3s;z-index:400;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<!-- PIN -->
<div class="screen active" id="screen-pin">
  <div class="pin-logo">Mon<span>Budget</span></div>
  <div class="pin-sub">Code par défaut : 1234</div>
  <div class="pin-dots"><div class="pin-dot" id="d0"></div><div class="pin-dot" id="d1"></div><div class="pin-dot" id="d2"></div><div class="pin-dot" id="d3"></div></div>
  <div class="pin-error" id="pin-error"></div>
  <div class="pin-pad">
    <button class="pin-btn" onclick="pinPress('1')">1</button><button class="pin-btn" onclick="pinPress('2')">2</button><button class="pin-btn" onclick="pinPress('3')">3</button>
    <button class="pin-btn" onclick="pinPress('4')">4</button><button class="pin-btn" onclick="pinPress('5')">5</button><button class="pin-btn" onclick="pinPress('6')">6</button>
    <button class="pin-btn" onclick="pinPress('7')">7</button><button class="pin-btn" onclick="pinPress('8')">8</button><button class="pin-btn" onclick="pinPress('9')">9</button>
    <button class="pin-btn zero" onclick="pinPress('0')">0</button><button class="pin-btn del" onclick="pinDel()">⌫</button>
  </div>
  <div class="pin-setup" onclick="openOv('ov-pin')">Changer le code PIN</div>
</div>

<!-- HOME -->
<div class="screen" id="screen-home">
  <div class="home-nav">
    <div class="home-logo">Mon<span>Budget</span></div>
    <div class="home-nav-btns">
      <button class="btn-icon" onclick="exportData()" title="Exporter">↑</button>
      <button class="btn-icon" onclick="document.getElementById('import-file').click()" title="Importer">↓</button>
      <button class="btn-icon" onclick="lockApp()" title="Verrouiller">🔒</button>
    </div>
  </div>
  <input type="file" id="import-file" accept=".json" style="display:none" onchange="importData(event)">
  <div class="home-body">
    <div class="home-title">Mes comptes</div>
    <div class="accounts-grid" id="accounts-grid"></div>
    <button class="btn-new-account" onclick="openNewAccount()">+ Nouveau compte</button>
  </div>
</div>

<!-- ACCOUNT -->
<div class="screen" id="screen-account">
  <div class="acc-nav">
    <button class="btn-back" onclick="goHome()">← Retour</button>
    <div class="acc-nav-title" id="acc-nav-title" onclick="openEditAccountName()">Compte ✏️</div>
    <div class="acc-nav-right">
      <button class="btn-icon" onclick="openNavMonth(-1)">‹</button>
      <div class="nav-month-pill" id="nav-month-label"></div>
      <button class="btn-icon" onclick="openNavMonth(1)">›</button>
    </div>
  </div>
  <div class="acc-tabs">
    <div class="acc-tab active" onclick="switchTab('depenses')">💳 Dépenses</div>
    <div class="acc-tab" onclick="switchTab('stats')">📊 Stats</div>
    <div class="acc-tab" onclick="switchTab('livre')">📖 Livre</div>
  </div>
  <div class="tab-panel active" id="panel-depenses">
    <div class="soldes">
      <div class="solde-card">
        <div class="solde-label l-a">Solde actuel</div>
        <div id="soldeActuel" class="solde-num actuel">—</div>
        <div class="solde-sub">Effectuées &amp; réconciliées</div>
        <button class="solde-edit-btn" onclick="editSolde()">modifier base</button>
      </div>
      <div class="solde-card">
        <div class="solde-label l-d">À débiter</div>
        <div id="soldeAvenir" class="solde-num avenir">—</div>
        <div class="solde-sub">Programmées restantes</div>
      </div>
      <div class="solde-card">
        <div class="solde-label l-p">Projeté</div>
        <div id="soldeProjecte" class="solde-num projete">—</div>
        <div class="solde-sub">Après tout</div>
      </div>
    </div>
    <div class="sync-bar">
