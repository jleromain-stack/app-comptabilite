function renderStats() {
  var cats = getAllCats();
  var catTotals = {};
  var i, item, cat;
  var n = new Date();
  for (i=0; i<statsPeriod; i++) {
    var m2 = n.getMonth()-i; var y2 = n.getFullYear();
    if (m2<0) { m2+=12; y2--; }
    var d2 = getAD(curAccountId, y2, m2);
    var all = (d2.effectuees||[]).concat((d2.programmees||[]).filter(isRec));
    for (var j=0; j<all.length; j++) {
      item = all[j]; cat = item.cat || 'autres';
      catTotals[cat] = (catTotals[cat]||0) + (parseFloat(item.amount)||0);
    }
  }
  var sorted = Object.entries(catTotals).sort(function(a,b){return b[1]-a[1];});
  var total = sorted.reduce(function(s,x){return s+x[1];}, 0) || 1;
  var bars = document.getElementById('chart-bars');
  if (!sorted.length) {
    bars.innerHTML = '<div class="empty">Aucune dépense sur cette période</div>';
    document.getElementById('pie-legend').innerHTML = '';
    return;
  }
  var bhtml = '';
  for (i=0; i<sorted.length; i++) {
    var entry = sorted[i]; cat = entry[0]; var amt = entry[1];
    var c = cats[cat] || cats.autres;
    bhtml += '<div class="bar-row">' +
      '<div class="bar-cat" style="color:' + c.color + '">' + c.label + '</div>' +
      '<div class="bar-track"><div class="bar-fill" style="width:' + Math.round(amt/total*100) + '%;background:' + c.color + '"></div></div>' +
      '<div class="bar-amt" style="color:' + c.color + '">' + fmt(amt) + '</div></div>';
  }
  bars.innerHTML = bhtml;
  var canvas = document.getElementById('pieChart');
  var ctx = canvas.getContext('2d');
  canvas.width = 180; canvas.height = 180; ctx.clearRect(0,0,180,180);
  var angle = -Math.PI/2;
  for (i=0; i<sorted.length; i++) {
    var c2 = cats[sorted[i][0]] || cats.autres;
    var slice = sorted[i][1]/total*2*Math.PI;
    ctx.beginPath(); ctx.moveTo(90,90); ctx.arc(90,90,80,angle,angle+slice); ctx.closePath();
    ctx.fillStyle = c2.color; ctx.fill();
    ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.stroke();
    angle += slice;
  }
  var lhtml = '';
  for (i=0; i<sorted.length; i++) {
    var c3 = cats[sorted[i][0]] || cats.autres;
    lhtml += '<div class="pie-leg-row"><div class="pie-leg-dot" style="background:' + c3.color + '"></div><div class="pie-leg-name">' + c3.label + '</div><div class="pie-leg-pct">' + Math.round(sorted[i][1]/total*100) + '% · ' + fmt(sorted[i][1]) + '</div></div>';
  }
  document.getElementById('pie-legend').innerHTML = lhtml;
}

// ── LIVRE ──
function renderNotes() {
  var notes = getNotes(curAccountId);
  var c = document.getElementById('notes-list');
  if (!notes.length) { c.innerHTML = '<div class="empty">Aucune note — tape "+ Note" pour commencer</div>'; return; }
  var html = '';
  for (var i=0; i<notes.length; i++) {
    var n = notes[i];
    html += '<div class="note-card" onclick="openEditNote(' + i + ')">' +
      '<div class="note-date">' + n.date + (n.title?' · <strong>'+n.title+'</strong>':'') + '</div>' +
      '<div class="note-preview">' + n.body + '</div></div>';
  }
  c.innerHTML = html;
}

function openNote() {
  editingNoteIdx = null;
  document.getElementById('note-title').textContent = 'Nouvelle note';
  document.getElementById('f-note-title').value = '';
  document.getElementById('f-note-body').value = '';
  document.getElementById('btn-del-note').style.display = 'none';
  openOv('ov-note');
  setTimeout(function() { document.getElementById('f-note-body').focus(); }, 300);
}

function openEditNote(i) {
  editingNoteIdx = i;
  var n = getNotes(curAccountId)[i];
  document.getElementById('note-title').textContent = 'Modifier la note';
  document.getElementById('f-note-title').value = n.title || '';
  document.getElementById('f-note-body').value = n.body;
  document.getElementById('btn-del-note').style.display = 'block';
  openOv('ov-note');
}

function saveNote() {
  var title = document.getElementById('f-note-title').value.trim();
  var body = document.getElementById('f-note-body').value.trim();
  if (!body) { showToast('Écris quelque chose'); return; }
  var notes = getNotes(curAccountId);
  var n = {title:title, body:body, date:new Date().toLocaleDateString('fr-FR')};
  if (editingNoteIdx !== null) notes[editingNoteIdx] = n; else notes.unshift(n);
  saveNotes(curAccountId, notes);
  closeOv('ov-note');
  renderNotes();
  showToast('Note enregistrée ✓');
}

function deleteNote() {
  if (!confirm('Supprimer cette note ?')) return;
  var notes = getNotes(curAccountId);
  notes.splice(editingNoteIdx, 1);
  saveNotes(curAccountId, notes);
  closeOv('ov-note');
  renderNotes();
  showToast('Note supprimée');
}

// ── MIC ──
var recognition = null; var isListening = false;
function toggleMic() {
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { showToast('Non supporté sur ce navigateur'); return; }
  if (isListening) { recognition.stop(); return; }
  recognition = new SR();
  recognition.lang = 'fr-FR'; recognition.continuous = false; recognition.interimResults = false;
  recognition.onstart = function() { isListening=true; document.getElementById('mic-fab').classList.add('listening'); };
  recognition.onend = function() { isListening=false; document.getElementById('mic-fab').classList.remove('listening'); };
  recognition.onresult = function(e) { parseVoice(e.results[0][0].transcript); };
  recognition.onerror = function() { isListening=false; document.getElementById('mic-fab').classList.remove('listening'); showToast('Erreur micro'); };
  recognition.start();
}

function parseVoice(text) {
  var t = text.toLowerCase();
  var match = t.match(/(\d+(?:[,.]\d{1,2})?)\s*(?:euro|euros|€)?/);
  var amount = match ? parseFloat(match[1].replace(',','.')) : null;
  if (!amount) { showToast('Montant non reconnu'); return; }
  var label = t.split(' ').filter(function(w){return w.length>2&&!/^\d/.test(w)&&['ajoute','euros','euro','dépense','revenu','mon','solde'].indexOf(w)===-1;}).slice(0,3).join(' ') || 'Entrée vocale';
  var d = getAD(curAccountId, curY, curM);
  if (!d.effectuees) d.effectuees=[];
  if (!d.revenus) d.revenus=[];
  if (!d.programmees) d.programmees=[];
  var item = {label:label, amount:amount, date:todayISO(), cat:guessCategory(label)};
  if (t.indexOf('revenu')!==-1||t.indexOf('salaire')!==-1) {
    d.revenus.push(item);
  } else if (t.indexOf('programm')!==-1||t.indexOf('prévu')!==-1) {
    item.checked = false; d.programmees.push(item);
  } else {
    d.effectuees.push(item);
  }
  saveAD(curAccountId, curY, curM, d);
  renderAccount();
  showToast(label + ' — ' + fmt(amount) + ' ajouté');
}
</script>
