  var k;
  for (k in localStorage) {
    if (k.indexOf('mb_') === 0 && k !== 'mb_accounts' && k !== 'mb_pin' && k.indexOf('mb_notes_') !== 0)
      bundle.data[k] = JSON.parse(localStorage.getItem(k));
    if (k.indexOf('mb_notes_') === 0)
      bundle.notes[k] = JSON.parse(localStorage.getItem(k));
  }
  var blob = new Blob([JSON.stringify(bundle,null,2)], {type:'application/json'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = 'monbudget-sauvegarde.json'; a.click();
