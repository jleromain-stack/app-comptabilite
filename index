<script>
// ── CONSTANTES ── v7
var MONTHS_FR = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
var MONTHS_S = ['Jan','Fév','Mar','Avr','Mai','Juin','Juil','Aoû','Sep','Oct','Nov','Déc'];
var MONTHS_NAMES = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
var DAYS = ['Lu','Ma','Me','Je','Ve','Sa','Di'];

var CATS_DEFAULT = {
  alimentation:{label:'Alim.',color:'#2A7A4A',bg:'#C8F0D8'},
  restaurant:{label:'Restaurant',color:'#A03050',bg:'#F5D5DC'},
  logement:{label:'Logement',color:'#1A5A9A',bg:'#D0E8F8'},
  transport:{label:'Transport',color:'#D4860A',bg:'#FDF3DC'},
  sante:{label:'Santé',color:'#6A2A9A',bg:'#EDD8F8'},
  abonnements:{label:'Abonnements',color:'#C05010',bg:'#FDDCC8'},
  shopping:{label:'Shopping',color:'#A03070',bg:'#F8D0E8'},
  loisirs:{label:'Loisirs',color:'#2A6A8A',bg:'#C8E8F4'},
  banque:{label:'Banque',color:'#4A4A4A',bg:'#E8E8E8'},
  autres:{label:'Autres',color:'#6A8C76',bg:'#E0EDE4'}
};

var PALETTE = [
  {color:'#C8526E',bg:'#F5D5DC',label:'Framboise'},
  {color:'#2A7A4A',bg:'#C8F0D8',label:'Vert'},
  {color:'#1A5A9A',bg:'#D0E8F8',label:'Bleu'},
  {color:'#D4860A',bg:'#FDF3DC',label:'Ambre'},
  {color:'#6A2A9A',bg:'#EDD8F8',label:'Violet'},
  {color:'#C05010',bg:'#FDDCC8',label:'Orange'},
  {color:'#A03070',bg:'#F8D0E8',label:'Rose'},
  {color:'#2A6A8A',bg:'#C8E8F4',label:'Canard'},
  {color:'#7A5A10',bg:'#F4E8C0',label:'Doré'},
  {color:'#3A7A6A',bg:'#C0EDE4',label:'Turquoise'},
  {color:'#8A2A2A',bg:'#F4C0C0',label:'Rouge'},
  {color:'#4A4A8A',bg:'#D0D0F4',label:'Indigo'}
];

var ENSEIGNE_CAT = {
  leclerc:'alimentation',carrefour:'alimentation',lidl:'alimentation',aldi:'alimentation',
  intermarche:'alimentation',monoprix:'alimentation',franprix:'alimentation',picard:'alimentation',
  mcdonalds:'restaurant',mcdonald:'restaurant',kfc:'restaurant',
  ubereats:'restaurant',deliveroo:'restaurant',
  sncf:'transport',ratp:'transport',uber:'transport',
  netflix:'abonnements',spotify:'abonnements',orange:'abonnements',sfr:'abonnements',
  bouygues:'abonnements',free:'abonnements',apple:'abonnements',
  amazon:'shopping',fnac:'shopping',zara:'shopping',
  pharmacie:'sante',medecin:'sante',
  edf:'logement',gdf:'logement'
};

// ── STATE ──
var curAccountId = null;
var curY = new Date().getFullYear();
var curM = new Date().getMonth();
var pinBuf = '';
var lockTimer = null;
var entryType = '';
var editingIdx = null;
var editingNoteIdx = null;
var editingAccountId = null;
var statsPeriod = 1;
var calY = new Date().getFullYear();
var calM = new Date().getMonth();
var calSel = null;
var newCatTarget = 'f-cat';
var paletteIdx = 0;

// ── UTILS ──
function getAllCats() {
  var custom = JSON.parse(localStorage.getItem('mb_custom_cats') || '{}');
  var merged = {};
  var k;
  for (k in CATS_DEFAULT) merged[k] = CATS_DEFAULT[k];
  for (k in custom) merged[k] = custom[k];
  return merged;
}

function fmt(n) {
  var num = parseFloat(n);
  if (isNaN(num)) return '0,00 €';
  return num.toLocaleString('fr-FR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' €';
}

function isoToDisplay(iso) {
  if (!iso) return '';
  var p = iso.split('-');
  var d = parseInt(p[2]);
  var m = parseInt(p[1]) - 1;
  var y = parseInt(p[0]);
  return d + ' ' + MONTHS_NAMES[m] + ' ' + y;
}

function todayISO() {
  var n = new Date();
  var d = String(n.getDate()).padStart(2,'0');
  var m = String(n.getMonth()+1).padStart(2,'0');
  return n.getFullYear() + '-' + m + '-' + d;
}

function makeISO(d, m, y) {
  return y + '-' + String(m+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
}

function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2500);
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
  document.getElementById(id).classList.add('active');
}

function openOv(id) {
  document.getElementById(id).classList.add('open');
}

function closeOv(id) {
  document.getElementById(id).classList.remove('open');
}

function closeOvOutside(id, e) {
  if (e.target === document.getElementById(id)) closeOv(id);
}

function guessCategory(label) {
  var l = (label || '').toLowerCase();
  var k;
  for (k in ENSEIGNE_CAT) {
    if (l.indexOf(k) !== -1) return ENSEIGNE_CAT[k];
  }
  return 'autres';
}

function catPill(cat) {
  var cats = getAllCats();
  if (!cat || !cats[cat]) return '';
  var c = cats[cat];
  return '<span class="cat-pill" style="background:' + c.bg + ';color:' + c.color + ';">' + c.label + '</span>';
}

// ── CATEGORIES ──
function buildCatOptions(sel) {
  var custom = JSON.parse(localStorage.getItem('mb_custom_cats') || '{}');
  var html = '<option value="">— Choisir —</option>';
  var k;
  for (k in CATS_DEFAULT) {
    html += '<option value="' + k + '"' + (sel===k?' selected':'') + '>' + CATS_DEFAULT[k].label + '</option>';
  }
  var keys = Object.keys(custom);
  if (keys.length) {
    html += '<optgroup label="Mes catégories">';
    for (var i=0; i<keys.length; i++) {
      k = keys[i];
      html += '<option value="' + k + '"' + (sel===k?' selected':'') + '>' + custom[k].label + '</option>';
    }
    html += '</optgroup>';
  }
  html += '<option value="__new__">＋ Nouvelle catégorie…</option>';
  return html;
}

function onCatChange(selectId) {
  var el = document.getElementById(selectId);
  if (el.value === '__new__') {
    el.value = '';
    newCatTarget = selectId;
    paletteIdx = 0;
    renderPalette();
    document.getElementById('f-newcat-name').value = '';
    openOv('ov-newcat');
    setTimeout(function() { document.getElementById('f-newcat-name').focus(); }, 300);
  }
}

function renderPalette() {
  var wrap = document.getElementById('palette-grid');
  var html = '';
  for (var i=0; i<PALETTE.length; i++) {
    var c = PALETTE[i];
    var sel = i === paletteIdx;
    html += '<div class="palette-dot' + (sel?' selected':'') + '" style="background:' + c.color + ';" onclick="selectPalette(' + i + ')" title="' + c.label + '"></div>';
  }
  wrap.innerHTML = html;
}

function selectPalette(i) {
  paletteIdx = i;
  renderPalette();
}

function saveNewCat() {
  var name = document.getElementById('f-newcat-name').value.trim();
  if (!name) { showToast('Donne un nom à la catégorie'); return; }
  var p = PALETTE[paletteIdx];
  var key = 'cat_' + Date.now();
  var custom = JSON.parse(localStorage.getItem('mb_custom_cats') || '{}');
  custom[key] = {label: name, color: p.color, bg: p.bg};
  localStorage.setItem('mb_custom_cats', JSON.stringify(custom));
  var el = document.getElementById(newCatTarget);
  if (el) el.innerHTML = buildCatOptions(key);
  closeOv('ov-newcat');
  showToast('Catégorie "' + name + '" créée ✓');
}

// ── CALENDRIER ──
function renderCal() {
  var label = document.getElementById('cal-nav-label');
  var grid = document.getElementById('cal-grid');
  var display = document.getElementById('cal-display');
  label.textContent = MONTHS_FR[calM] + ' ' + calY;
  display.textContent = calSel ? isoToDisplay(calSel) : 'Aucune date sélectionnée';
  var today = new Date();
  var html = '';
  var i;
  for (i=0; i<7; i++) html += '<div class="cal-head">' + DAYS[i] + '</div>';
  var first = new Date(calY, calM, 1).getDay();
  var offset = (first + 6) % 7;
  var daysInMonth = new Date(calY, calM+1, 0).getDate();
  for (i=0; i<offset; i++) html += '<div class="cal-day empty"></div>';
  for (var d=1; d<=daysInMonth; d++) {
    var iso = makeISO(d, calM, calY);
    var cls = 'cal-day';
    if (today.getDate()===d && today.getMonth()===calM && today.getFullYear()===calY) cls += ' today-mark';
    if (calSel === iso) cls += ' selected';
    html += '<div class="' + cls + '" onclick="calSelect(\'' + iso + '\')">' + d + '</div>';
  }
  grid.innerHTML = html;
}

function calSelect(iso) { calSel = iso; renderCal(); }

function calMove(dir) {
  calM += dir;
  if (calM > 11) { calM = 0; calY++; }
  if (calM < 0) { calM = 11; calY--; }
  renderCal();
}

function initCal(preselect) {
  var n = new Date();
  if (preselect) {
    calSel = preselect;
    var p = preselect.split('-');
    calY = parseInt(p[0]);
    calM = parseInt(p[1]) - 1;
  } else {
    calSel = todayISO();
    calY = n.getFullYear();
    calM = n.getMonth();
  }
  renderCal();
}

// ── PIN ──
function getPin() { return localStorage.getItem('mb_pin') || '1234'; }

function pinPress(d) {
  if (pinBuf.length >= 4) return;
  pinBuf += d;
  updDots();
  if (pinBuf.length === 4) setTimeout(checkPin, 100);
}

function pinDel() { pinBuf = pinBuf.slice(0,-1); updDots(); }

function updDots() {
  for (var i=0; i<4; i++)
    document.getElementById('d'+i).classList.toggle('filled', i < pinBuf.length);
}

function checkPin() {
  if (pinBuf === getPin()) {
    document.getElementById('pin-error').textContent = '';
    showScreen('screen-home');
    renderHome();
    resetLock();
  } else {
    document.getElementById('pin-error').textContent = 'Code incorrect';
    pinBuf = '';
    updDots();
  }
}

function lockApp() { showScreen('screen-pin'); pinBuf = ''; updDots(); }
function resetLock() { clearTimeout(lockTimer); lockTimer = setTimeout(lockApp, 5*60*1000); }
document.addEventListener('click', resetLock);

function savePIN() {
  var a = document.getElementById('f-pin1').value;
  var b = document.getElementById('f-pin2').value;
  if (!/^\d{4}$/.test(a)) { showToast('4 chiffres requis'); return; }
  if (a !== b) { showToast('Les codes ne correspondent pas'); return; }
  localStorage.setItem('mb_pin', a);
  closeOv('ov-pin');
  showToast('PIN mis à jour ✓');
}

// ── DATA ──
function getAccounts() { return JSON.parse(localStorage.getItem('mb_accounts') || '[]'); }
function saveAccounts(a) { localStorage.setItem('mb_accounts', JSON.stringify(a)); }

function getAD(id, y, m) {
  var raw = localStorage.getItem('mb_' + id + '_' + y + '_' + m);
  if (raw) return JSON.parse(raw);
  return {solde:null, solde_sync:null, sync_date:null, revenus:[], effectuees:[], programmees:[]};
}

function saveAD(id, y, m, d) {
  localStorage.setItem('mb_' + id + '_' + y + '_' + m, JSON.stringify(d));
}

function getNotes(id) { return JSON.parse(localStorage.getItem('mb_notes_' + id) || '[]'); }
function saveNotes(id, n) { localStorage.setItem('mb_notes_' + id, JSON.stringify(n)); }

function isRec(item) {
  if (item.checked) return true;
  if (item.date) {
    var t = new Date(); t.setHours(0,0,0,0);
    return new Date(item.date + 'T00:00:00') <= t;
  }
  return false;
}

function calcS(d) {
  var base = parseFloat(d.solde) || 0;
  var rev = 0; var eff = 0; var rec = 0; var prog = 0;
  var i;
  for (i=0; i<d.revenus.length; i++) rev += parseFloat(d.revenus[i].amount) || 0;
  for (i=0; i<d.effectuees.length; i++) eff += parseFloat(d.effectuees[i].amount) || 0;
  for (i=0; i<d.programmees.length; i++) {
    var amt = parseFloat(d.programmees[i].amount) || 0;
    if (isRec(d.programmees[i])) rec += amt; else prog += amt;
  }
  var actuel = base + rev - eff - rec;
  return {actuel: actuel, prog: prog, projete: actuel - prog};
}

